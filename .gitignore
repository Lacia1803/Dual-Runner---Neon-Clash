# This .gitignore file should be placed at the root of your Unity project.
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Ob]j/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive
/[Mm]emoryCaptures/

# Recorded songs can get excessive
/[Rr]ecordings/

# Asset rip results
/[Aa]sset[Rr]ip/

# Exported Visual Studio project
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.IDB
/*.VC.db

# Unity3D generated meta files
/*.pidb.meta
/*.pdb.meta
/*.metadata

# Unity3D generated file is added to ignore list
# (The Unity3D project settings and assets should be tracked)
/[Aa]ssets/AssetStoreTools*

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio Code solution folder
/.vscode/

# Crashlytics generated file
crashlytics-build.properties

# Packed packages
/*.tgz

# CMake generate artifacts
/CMakeSettings.json
/CMakeLists.txt
/CMakeCache.txt
/CMakeFiles/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
